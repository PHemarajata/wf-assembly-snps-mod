/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Burkholderia pseudomallei (BP) clustering science defaults

    This profile sets workflow-level params that are appropriate for BP population
    genomics work. It does NOT set any hardware-specific resource limits — combine
    with one of the workstation profiles (local_workstation, local_workstation_rtx4070)
    and a container profile (docker, singularity).

    Example:
        nextflow run main.nf \
            -profile bp,local_workstation_rtx4070,docker \
            --input  /path/to/assemblies/ \
            --outdir /path/to/results/

    Rationale for each default (see BP_CLUSTERING_HANDOFF.md for full context):
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'BP clustering'
    config_profile_description = 'Burkholderia pseudomallei population-genomics defaults (recombination-aware mode, larger Mash sketches, broad-clade threshold).'

    // BP recombination is the highest reported r/m ratio of any bacterium (18-30x);
    // Gubbins recombination masking is non-optional for valid phylogeny.
    recombination_aware_mode   = true
    integrate_results          = true

    // Larger Mash sketches stabilize the distance distribution near tight
    // thresholds. Default 10k is undersized for 300+ BP genomes; 50k matches
    // the lower bound of the handoff recommendation (50k-100k).
    mash_sketch_size           = 50000

    // Broad-clade Mash threshold used in the BP handoff §5 production command.
    // Captures geographic clades rather than fine-scale outbreak clusters; tune
    // tighter (0.005-0.007) when fine-scale relatedness is the question, looser
    // for purely broad-population grouping. Always validate with a sweep on the
    // actual dataset before committing to a threshold.
    mash_threshold             = 0.028

    // Conservative cluster cap that splits large geographic groups into
    // tractable units for per-cluster Gubbins/IQ-TREE on a workstation.
    // Pair with merge_singletons=true to avoid trivial singleton trees.
    max_cluster_size           = 50
    merge_singletons           = true

    // SNP/recombination toolchain — matches the BP handoff §5 command.
    snp_package                = "parsnp"
    recombination              = "gubbins"
    run_gubbins                = true
    alignment_method           = "snippy"
    scalable_mode              = false
}
